FUSIONAUTH_API_KEY=CHANGEME # API key with /api/theme (GET,PATCH)
FUSIONAUTH_HOST=https://auth.example.com # protocol + hostname only, no paths
THEME_ID=CHANGEME # your theme's UUID
TMP_DIR=tpl # canonical local theme folder used by download/watch/upload

# Optional: where email templates are downloaded
# EMAILS_DIR=./email-templates/emails

# Optional: template id used as the branded HTML wrapper when duplicating with "Brand on duplicate"
# EMAIL_BRAND_TEMPLATE_ID=375773f7-911d-49e5-8ea8-e9f5eb723521

# Optional: local FreeMarker preview service base URL (email-preview-java)
# EMAIL_PREVIEW_FM_URL=http://localhost:4561

# Legacy names (still supported by env.sh)
# API_KEY=CHANGEME
# FUSIONAUTH_URL=https://auth.example.com
