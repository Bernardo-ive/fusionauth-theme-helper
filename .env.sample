FUSIONAUTH_API_KEY=CHANGEME # API key with /api/theme (GET,PATCH)
FUSIONAUTH_HOST=https://auth.example.com # protocol + hostname only, no paths
THEME_ID=CHANGEME # your theme's UUID
TMP_DIR=tmp # a temporary directory; this will be created

# Optional: where email templates are downloaded
# EMAILS_DIR=./email-templates/emails

# Legacy names (still supported by env.sh)
# API_KEY=CHANGEME
# FUSIONAUTH_URL=https://auth.example.com
